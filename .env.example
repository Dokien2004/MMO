# Affiliate MVP Laptop
# Copy file này thành .env nếu sau này dùng loader env riêng hoặc export biến trước khi chạy worker.

APP_ENV=development
APP_DEBUG=true

# OpenAI: không bắt buộc. Thiếu key thì hệ thống fallback về template_engine.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini: ưu tiên dùng khi OpenAI lỗi hoặc chọn provider gemini/auto.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Facebook Fanpage API: không bắt buộc. Thiếu token thì dùng fanpage_manual.
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_GRAPH_VERSION=v23.0

# Server local
APP_HOST=0.0.0.0
APP_PORT=8088

# Database thật (MariaDB/MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mmo_affiliate
DB_USERNAME=root
DB_PASSWORD=
