# Affiliate MVP Laptop cron sample
# Chay theo dot moi 4 gio
0 */4 * * * /usr/bin/php /opt/lampp/htdocs/affiliate-mvp-laptop/workers/run_pipeline.php affiliate_api /opt/lampp/htdocs/affiliate-mvp-laptop/storage/data/sources/sample_products.json MVP-LAPTOP template_engine fanpage_manual 10 >> /opt/lampp/htdocs/affiliate-mvp-laptop/storage/logs/pipeline.log 2>&1

# Publish cac bai scheduled theo Fanpage API moi 15 phut
*/15 * * * * /usr/bin/php /opt/lampp/htdocs/affiliate-mvp-laptop/workers/publish_scheduled_posts.php 10 >> /opt/lampp/htdocs/affiliate-mvp-laptop/storage/logs/publish.log 2>&1

# Cao du lieu san pham ban chay tu Shopee/TikTok moi 6 gio
0 */6 * * * /usr/bin/php /opt/lampp/htdocs/affiliate-mvp-laptop/workers/run_scraper.php >> /opt/lampp/htdocs/affiliate-mvp-laptop/storage/logs/scraper.log 2>&1

